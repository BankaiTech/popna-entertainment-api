# ─── Django ────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ──────────────────────────────────────────────────────────────
DB_ENGINE=sqlite
DB_BACKEND=mysql.connector.django
SQLITE_NAME=db.sqlite3

# ─── Database (MySQL - use when DB_ENGINE=mysql) ──────────────────────────
DB_NAME=popna_db
DB_USER=root
DB_PASSWORD=Popna@123
# Use a direct MySQL endpoint/IP, not a website domain behind Cloudflare.
DB_HOST=db.popnaentertainment.com
DB_PORT=3306

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_ACCESS_HOURS=8
JWT_REFRESH_DAYS=7

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
